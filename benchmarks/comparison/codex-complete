#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#
# Thin "completion" wrapper around `codex exec` for use as an Artesian LlmClient
# (headgate CommandLlmClient): reads a prompt from stdin, prints the model's final
# message to stdout. Used by `gauge-eval` to answer and grade benchmark questions.
#
# Env overrides:
#   CODEX_MODEL      (default: gpt-5.5)
#   CODEX_REASONING  (default: xhigh)
set -euo pipefail

prompt="$(cat)"
out="$(mktemp)"
trap 'rm -f "$out"' EXIT

codex exec \
  -m "${CODEX_MODEL:-gpt-5.5}" \
  -c model_reasoning_effort="${CODEX_REASONING:-xhigh}" \
  --skip-git-repo-check \
  --ephemeral \
  -s read-only \
  --output-last-message "$out" \
  -- "$prompt" >/dev/null 2>&1

cat "$out"
